# ═══════════════════════════════════════════════════
# LIGUE 1 PREDICTOR BOT - Configuration
# ═══════════════════════════════════════════════════
# Copiez ce fichier en .env et remplissez vos valeurs:
#   cp .env.example .env

# ─── REQUIS ───
# Token Telegram (depuis @BotFather)
TELEGRAM_BOT_TOKEN=votre_token_ici

# ─── OPTIONNEL - Données live ───
# API-Football (gratuit: https://www.api-football.com - 100 req/jour)
API_FOOTBALL_KEY=

# The Odds API (gratuit: https://the-odds-api.com - 500 req/mois)
ODDS_API_KEY=

# ─── OPTIONNEL - Affiliations bookmakers ───
# Remplissez uniquement ceux que vous avez configuré
BETCLIC_AFFILIATE_ID=
WINAMAX_AFFILIATE_ID=
UNIBET_AFFILIATE_ID=
ONEXBET_AFFILIATE_ID=
PMU_AFFILIATE_ID=
PARIONSSPORT_AFFILIATE_ID=
BWIN_AFFILIATE_ID=
ZEBET_AFFILIATE_ID=
