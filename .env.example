# Vaulty Card Analyzer - Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# === OPTIONAL - Admin Users ===
ADMIN_USER_IDS=123456789,987654321

# === OPTIONAL - External Search APIs ===
# SerpAPI for Google Lens reverse image search (most powerful)
# Get your key at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Google Custom Search (alternative to SerpAPI)
# Get your keys at: https://developers.google.com/custom-search/v1/overview
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Pokemon TCG API (optional, increases rate limits)
# Get your key at: https://dev.pokemontcg.io/
POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key_here
